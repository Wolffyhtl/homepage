---
const navLinks = [
  { href: '#home', label: '首页' },
  { href: '#about', label: '关于我' },
  { href: '#skills', label: '技能' },
  { href: '#projects', label: '项目' },
  { href: '#contact', label: '联系' },
];

const updateTime = () => {
  const now = new Date();
  const utc8Time = new Date(now.getTime() + (8 * 60 * 60 * 1000));
  const timeString = utc8Time.toLocaleString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false
  }).replace(/\//g, '-');
  return timeString;
};
---

<header class="sticky top-0 z-50 glass-light">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="#home" class="text-2xl font-bold text-gradient hover-lift">Clina 的个人网站</a>

      <div class="hidden md:flex space-x-8 items-center">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-white hover:text-gray-200 transition-colors duration-300 hover-lift py-2"
          >
            {link.label}
          </a>
        ))}
        <div class="text-white text-sm font-medium whitespace-nowrap">
          <span id="currentTime"></span>
        </div>
      </div>

      <button class="md:hidden glass p-2" aria-label="打开菜单" id="mobileMenuButton">
        <svg class="w-6 h-6 text-indigo-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- 移动端菜单 -->
    <div class="md:hidden fixed top-16 left-0 right-0 z-40 transform transition-transform duration-300 translate-x-full" id="mobileMenu">
      <div class="glass-light p-6 mt-2 backdrop-blur-md">
        <div class="flex flex-col space-y-4">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-white hover:text-gray-200 transition-colors duration-300 py-2 border-b border-gray-300 last:border-b-0"
            >
              {link.label}
            </a>
          ))}
          <div class="text-white text-sm font-medium text-center pt-4 border-t border-gray-300">
            <span id="mobileTime"></span>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <script>
    // 更新时间显示 - 调用系统本地时间
    function updateTimeDisplay() {
      const now = new Date();

      const hours = String(now.getHours()).padStart(2, '0');
      const minutes = String(now.getMinutes()).padStart(2, '0');
      const seconds = String(now.getSeconds()).padStart(2, '0');

      const timeString = `${hours}:${minutes}:${seconds}`;
      const timeElement = document.getElementById('currentTime');
      if (timeElement) {
        timeElement.textContent = timeString;
      }

      const mobileTimeElement = document.getElementById('mobileTime');
      if (mobileTimeElement) {
        mobileTimeElement.textContent = timeString;
      }
    }

    // 移动端菜单切换
    function toggleMobileMenu() {
      const menu = document.getElementById('mobileMenu') as HTMLElement | null;
      const button = document.getElementById('mobileMenuButton') as HTMLElement | null;
      if (menu && button) {
        const isOpen = menu.classList.contains('translate-x-0');
        menu.classList.toggle('translate-x-full');
        menu.classList.toggle('translate-x-0');
        button.setAttribute('aria-expanded', String(!isOpen));
      }
    }

    // 初始化
    document.addEventListener('DOMContentLoaded', () => {
      const button = document.getElementById('mobileMenuButton') as HTMLElement | null;
      if (button) {
        button.addEventListener('click', toggleMobileMenu);
      }

      // 点击菜单外部关闭菜单
      document.addEventListener('click', (e: Event) => {
        const menu = document.getElementById('mobileMenu') as HTMLElement | null;
        const button = document.getElementById('mobileMenuButton') as HTMLElement | null;
        const target = e.target as Node;
        if (menu && button && !menu.contains(target) && !button.contains(target)) {
          menu.classList.add('translate-x-full');
          menu.classList.remove('translate-x-0');
          button.setAttribute('aria-expanded', 'false');
        }
      });

      // 点击菜单链接关闭菜单
      const menuLinks = document.querySelectorAll('#mobileMenu a[href^="#"]');
      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          const menu = document.getElementById('mobileMenu') as HTMLElement | null;
          const button = document.getElementById('mobileMenuButton') as HTMLElement | null;
          if (menu && button) {
            menu.classList.add('translate-x-full');
            menu.classList.remove('translate-x-0');
            button.setAttribute('aria-expanded', 'false');
          }
        });
      });
    });

    // 每秒更新时间
    updateTimeDisplay();
    setInterval(updateTimeDisplay, 1000);
  </script>
</header>