---
const contacts = [
  {
    name: '邮箱',
    url: 'mailto:clina@inventati.org',
    icon: '📧',
    color: 'from-red-500 to-red-600',
  }
];
---

<section class="container mx-auto px-6 py-16">
  <div class="glass p-8 hover-lift">
    <h2 class="text-3xl font-bold text-gradient mb-8 text-center">联系方式</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {contacts.map((contact, index) => (
        <a
          data-key={index}
          href={contact.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block text-center"
        >
          <div class="glass-light p-4 hover-lift transition-all duration-300 group-hover:scale-105">
            <div class={`w-12 h-12 rounded-full bg-gradient-to-br ${contact.color} flex items-center justify-center text-white text-xl mx-auto mb-3 group-hover:scale-110 transition-transform duration-300`}>
              {contact.icon}
            </div>
            <p class="text-indigo-300 text-sm font-medium group-hover:text-indigo-200 transition-colors duration-300">
              {contact.name}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>