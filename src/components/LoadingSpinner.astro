---
---

<div class="fixed inset-0 bg-gradient-to-br from-gray-100 to-gray-300 flex items-center justify-center z-50" id="loadingSpinner">
  <div class="text-center">
    <!-- Windows 10风格加载圆圈 -->
    <div class="w-16 h-16 rounded-full border-4 border-gray-400 border-t-gray-800 animate-spin mx-auto"></div>

    <!-- 加载文字 -->
    <div class="mt-6 text-center">
      <p class="text-[#ffffff] text-sm animate-pulse">正在加载资源...</p>
      <p class="text-[#ffffff] text-xs mt-1">Personal Website</p>
    </div>

    <!-- 进度条 -->
    <div class="w-32 mx-auto mt-4 bg-gray-400 rounded-full h-1">
      <div class="bg-gray-800 h-1 rounded-full animate-pulse" style="width: 0%"></div>
    </div>
  </div>
</div>

<style is:global>
  @keyframes win10Spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .animate-win10Spin {
    animation: win10Spin 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      visibility: visible;
      backdrop-filter: blur(0px);
    }
    to {
      opacity: 0;
      visibility: hidden;
      backdrop-filter: blur(10px);
    }
  }

  .fade-out {
    animation: fadeOut 1s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    animation-delay: 1.5s;
  }

  @keyframes slideUp {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-100vh);
    }
  }

  .slide-up {
    animation: slideUp 1s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    animation-delay: 1.8s;
  }
</style>

<script>
  // 隐藏header和其他内容
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('header');
    const main = document.querySelector('main');
    const footer = document.querySelector('footer');

    if (header) header.style.opacity = '0';
    if (main) main.style.opacity = '0';
    if (footer) footer.style.opacity = '0';
  });

  // 模拟加载进度
  let progress = 0;
  const progressBar = document.querySelector('#loadingSpinner .bg-gray-800') as HTMLElement | null;
  const loadingText = document.querySelector('#loadingSpinner p:first-child') as HTMLElement | null;

  // 更新进度条
  const updateProgress = () => {
    progress += Math.random() * 30;
    if (progress > 100) progress = 100;

    if (progressBar) {
      progressBar.style.width = progress + '%';
    }

    // 根据进度更新文字
    if (loadingText) {
      if (progress < 30) {
        loadingText.textContent = '正在初始化...';
      } else if (progress < 60) {
        loadingText.textContent = '正在加载资源...';
      } else if (progress < 90) {
        loadingText.textContent = '正在加载壁纸...';
      } else {
        loadingText.textContent = '加载完成！';
      }
    }

    if (progress < 100) {
      setTimeout(updateProgress, 200);
    } else {
      // 加载完成后显示内容
      setTimeout(() => {
        const spinner = document.getElementById('loadingSpinner') as HTMLElement | null;
        const header = document.querySelector('header');
        const main = document.querySelector('main');
        const footer = document.querySelector('footer');

        // 显示内容并添加过渡动画
        if (header) {
          header.style.transition = 'opacity 1.5s ease-in-out';
          header.style.opacity = '1';
        }
        if (main) {
          main.style.transition = 'opacity 1.5s ease-in-out';
          main.style.opacity = '1';
        }
        if (footer) {
          footer.style.transition = 'opacity 1.5s ease-in-out';
          footer.style.opacity = '1';
        }

        // 加载完成后立即加载Bing壁纸
        loadBingWallpaper();

        // 隐藏加载界面
        if (spinner) {
          spinner.classList.add('fade-out');
          spinner.classList.add('slide-up');
          setTimeout(() => {
            if (spinner) spinner.style.display = 'none';
          }, 2500);
        }
      }, 500);
    }
  };

  // 获取Bing壁纸 - 使用直接支持CORS的API
  async function loadBingWallpaper() {
    try {
      // 方法1: 使用bing.biturl.top API (直接返回JSON)
      const api1 = 'https://bing.biturl.top/';

      // 方法2: 使用每日必应美图API
      const api2 = 'https://api.bingimg.cn/bing';

      let imageUrl = null;

      // 尝试API 1
      try {
        const response = await fetch(api1);
        if (response.ok) {
          const data = await response.json();
          if (data && data.url) {
            imageUrl = data.url;
            console.log('Bing壁纸API1成功:', imageUrl);
          }
        }
      } catch (e) {
        console.warn('Bing壁纸API1失败:', e.message);
      }

      // 如果API1失败，尝试API2
      if (!imageUrl) {
        try {
          const response = await fetch(api2);
          if (response.ok) {
            const data = await response.json();
            if (data && data.images && data.images.length > 0) {
              imageUrl = data.images[0].url;
              console.log('Bing壁纸API2成功:', imageUrl);
            }
          }
        } catch (e) {
          console.warn('Bing壁纸API2失败:', e.message);
        }
      }

      if (imageUrl) {
        document.documentElement.style.setProperty('--bing-bg-image', `url('${imageUrl}')`);
        document.body.classList.add('bing-bg');
        console.log('Bing壁纸加载成功:', imageUrl);
      } else {
        console.log('无法获取Bing壁纸，使用默认靛蓝色渐变背景');
      }
    } catch (error) {
      console.log('Bing壁纸加载失败，使用默认背景:', error.message);
    }
  }

  // 开始加载
  updateProgress();
</script>

