      // 加载完成后隐藏
      setTimeout(() => {
        const spinner = document.getElementById('loadingSpinner') as HTMLElement | null;
        if (spinner) {
          spinner.classList.add('fade-out');
          setTimeout(() => {
            if (spinner) spinner.style.display = 'none';
          }, 500);
        }
      }, 500);
    }
  };

  // 开始加载
  updateProgress();
</script>