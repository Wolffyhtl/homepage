---
import websites from '../json/websites.json';
---

<section class="container mx-auto px-6 py-16">
  <div class="glass p-8 hover-lift">
    <h2 class="text-3xl font-bold text-gradient mb-8 text-center">我的网站</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {websites.map((site, index) => (
        <a
          data-key={index}
          href={site.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block"
        >
          <div class="glass-light p-6 hover-lift transition-all duration-300 group-hover:scale-105">
            <div class="flex items-center mb-4">
              <div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${site.color} flex items-center justify-center text-white text-xl mr-4 group-hover:scale-110 transition-transform duration-300`}>
                {site.icon}
              </div>
              <div>
                <h3 class="text-lg font-semibold text-indigo-300 group-hover:text-indigo-200 transition-colors duration-300">
                  {site.title}
                </h3>
              </div>
            </div>
            <p class="text-indigo-100 text-sm leading-relaxed mb-3">
              {site.description}
            </p>
            <div class="flex items-center text-indigo-400 text-sm font-medium group-hover:text-indigo-300 transition-colors duration-300">
              <span>访问网站</span>
              <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>